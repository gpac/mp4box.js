{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "es2022",
    "module": "es2022",
    "paths": {
      "#/*": ["./src/*"],
      "@types": ["./entries/types"],
      "entries/*": ["./entries/*"]
    }
  },
  "include": ["./src/**/*", "./entries/**/*"]
}
